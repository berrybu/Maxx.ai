# Maxx 环境配置 —— 复制为 .env 后填入真实值

# Cala 知识图谱 API（外部实体事实层）
CALA_API_KEY=your_cala_api_key_here
CALA_BASE_URL=https://api.cala.ai

# LLM 后端：ollama（本地）或 bricksllm（托管 OpenAI 兼容代理）
LLM_PROVIDER=bricksllm

# 本地 Ollama LLM（LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=2048

# BricksLLM 托管代理（LLM_PROVIDER=bricksllm 时使用）
BRICKSLLM_API_KEY=your_bricksllm_api_key_here
BRICKSLLM_ENDPOINT=https://bricksllm.chatbmw-secure.azure.bmw.cloud
BRICKSLLM_MODEL=gpt-4o
BRICKSLLM_API_VERSION=2024-10-21

# 邮件发送。EMAIL_MOCK=1 只记录到 outbox.json（不真发）；设 0 才走真实 SMTP。
# Gmail：开两步验证后到 myaccount.google.com/apppasswords 生成16位应用专用密码，
#        填到 SMTP_PASSWORD（去掉空格，连写成16位）。端口用 587（STARTTLS）。
EMAIL_MOCK=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password_no_spaces
EMAIL_FROM=your_email@gmail.com

# 卖家身份（写邮件时用）
SELLER_NAME=Tim
SELLER_COMPANY="EuroCircuit PCB"
SELLER_DESC="德国高可靠性印制电路板(PCB)制造商"
PRODUCT_DOC=docs/pcb_product_doc.md
